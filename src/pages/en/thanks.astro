---
import Layout from "../../layouts/Layout.astro";
---

<Layout
 lang="en"
 title="Thanks for your message - Rafa Garcia"
 description="Message sent successfully from Rafa Garcia's portfolio."
>
 <section class="mx-auto grid min-h-[calc(100vh-10rem)] max-w-4xl place-items-center px-5 py-20 text-center sm:px-8">
  <div class="glass-card relative overflow-hidden rounded-[2rem] px-6 py-14 sm:px-14 sm:py-18">
   <div class="absolute left-1/2 top-0 h-48 w-96 -translate-x-1/2 rounded-full bg-yellow-200/10 blur-3xl"></div>
   <div class="relative">
    <p class="eyebrow">Message sent</p>
    <h1 class="mt-4 text-4xl font-bold tracking-[-.04em] text-white sm:text-5xl">Thank you</h1>
    <p class="mx-auto mt-5 max-w-xl text-lg leading-8 text-white/65">I will get back to you as soon as possible.</p>
    <a href="/en/" class="mt-8 inline-flex items-center justify-center rounded-full bg-yellow-200 px-7 py-3.5 font-semibold !text-black transition hover:-translate-y-0.5 hover:bg-yellow-100">Back to portfolio</a>
   </div>
  </div>
 </section>
</Layout>
