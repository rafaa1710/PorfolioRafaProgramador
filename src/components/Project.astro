---
import Angular from "../icons/Angular.astro";
import Typescript from "../icons/Typescript.astro";
import Spring from "../icons/Spring.astro";
import Mariadb from "../icons/Mariadb.astro";
import Php from "../icons/Php.astro";
import Mysql from "../icons/Mysql.astro";
import AstroIcon from "../icons/Astro.astro";
import Css from "../icons/Css.astro";
const { lang = "es" } = Astro.props;
const en = lang === "en";
const base=import.meta.env.BASE_URL.endsWith("/")?import.meta.env.BASE_URL:import.meta.env.BASE_URL+"/";
const media={video:base+"result.mp4",bdi:base+"bdi-company-2.mp4",erp:[base+"sge1.jpg",base+"sge2.jpg",base+"sge3.jpg",base+"sge4.jpg",base+"sge5.jpg"]};
const projects=en?[
 {id:"bdi-company",title:"BDI Company corporate website",summary:"Development of a corporate website for a remodeling and construction company in the United States.",description:"I developed a corporate web application focused on attracting new clients for BDI Company. Potential clients can explore its services, view completed projects through image and video galleries, and contact the team directly using a form connected to the company email.",highlights:["Services overview and multimedia project galleries","Contact form focused on lead generation","Responsive design and advance SEO optimization","Google Analytics and custom domain"],tags:["Astro","CSS"],video:media.bdi,images:[]},
 {id:"trasterush",title:"Storage Rental Platform",description:"I developed a full stack storage rental application using Angular, a Spring Boot REST API and MariaDB. It includes payments, digital signatures and an admin panel protected through authentication and authorization for managing rentals and users. An ESP32 queries the API to validate access and activate the electronic lock.",highlights:["Rental, payment and digital signature","Restricted admin panel for rental and user management","IoT integration for physical access","Automated Gmail notifications"],tags:["Angular","TypeScript","Spring Boot","MariaDB","ESP32"],video:media.video,images:[]},
 {id:"erp-crm",title:"Modular ERP and CRM system",summary:"Unified management of students, training, users and administrative processes for an institutional environment.",description:"I developed and integrated connected modules built on a complex relational model. The focus was maintaining data consistency and making internal management workflows clearer.",highlights:["Interconnected modules and permissions","Relational data model","Centralised administrative workflows"],tags:["Angular","TypeScript","PHP","MySQL"],images:media.erp}
]:[
 {id:"bdi-company",title:"Sitio web corporativo para BDI Company",summary:"Desarrollo y mantenimiento de sitio web corporativo para una empresa de remodelación y construcción en Estados Unidos.",description:"Desarrollé una aplicación web corporativa orientada a captar nuevos clientes para BDI Company. Los potenciales clientes pueden conocer los servicios de la empresa, consultar trabajos realizados mediante galerías de imágenes y vídeos, y contactar directamente con el equipo a través de un formulario conectado al correo electrónico de la empresa.",highlights:["Presentación de servicios y galerías multimedia","Formulario orientado a la captación de clientes","Diseño responsive y optimización SEO avanzada","Google Analytics y dominio personalizado"],tags:["Astro","CSS"],video:media.bdi,images:[]},
 {id:"trasterush",title:"Plataforma de Alquiler de Trasteros",description:"Desarrollé una aplicación full stack para alquilar trasteros con Angular, una API REST en Spring Boot y MariaDB. Incluye pagos, firma digital y un panel protegido mediante autenticación y autorización desde el que el administrador gestiona alquileres y usuarios. Un ESP32 consulta la API para validar el acceso y accionar la cerradura electrónica.",highlights:["Contratación, Protección de rutas, pago y firma digital","Panel restringido para gestionar alquileres y usuarios","Integración IoT para acceso físico","Sistema de notificaciones automatizadas mediante Gmail"],tags:["Angular","TypeScript","Spring Boot","MariaDB","ESP32"],video:media.video,images:[]},
 {id:"erp-crm",title:"Sistema modular ERP y CRM",summary:"Gestión unificada de alumnos, formación, usuarios y procesos administrativos para un entorno institucional.",description:"Desarrollé e integré módulos conectados sobre un modelo relacional complejo. El foco estuvo en mantener la consistencia de la información y hacer más claros los flujos de gestión internos.",highlights:["Módulos y permisos interconectados","Modelo de datos relacional","Flujos administrativos centralizados"],tags:["Angular","TypeScript","PHP","MySQL"],images:media.erp}
];
const TAG_ICONS: Partial<Record<string, typeof Angular>>={Angular,TypeScript:Typescript,"Spring Boot":Spring,MariaDB:Mariadb,PHP:Php,MySQL:Mysql,Astro:AstroIcon,CSS:Css};
---
<div class="grid gap-10">{projects.map(project=><article id={project.id} class="glass-card overflow-hidden rounded-[2rem]"><div class="grid gap-8 p-6 sm:p-9 lg:grid-cols-[.8fr_1.4fr] lg:p-12"><div><h3 class="text-3xl font-semibold leading-tight tracking-[-.035em] text-white">{project.title}</h3>{project.summary&&<p class="mt-4 text-lg font-medium leading-7 text-white/85">{project.summary}</p>}<p class="mt-5 leading-7 text-white/55">{project.description}</p><ul class="mt-6 space-y-2 text-sm text-white/70">{project.highlights.map(item=><li class="flex gap-3"><span class="text-yellow-200">✓</span>{item}</li>)}</ul><ul class="mt-7 flex flex-wrap gap-2">{project.tags.map(tag=>{const Icon=TAG_ICONS[tag];return <li class="flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-xs font-medium text-white/65">{Icon&&<Icon class="size-4"/>}{tag}</li>})}</ul></div><div class="relative self-center overflow-hidden rounded-2xl border border-white/10 bg-black/30 shadow-2xl">{project.video?<><span data-video-hint class="pointer-events-none absolute left-1/2 top-4 z-10 -translate-x-1/2 animate-bounce whitespace-nowrap rounded-full border border-yellow-200/30 bg-black/80 px-4 py-2 text-xs font-semibold text-yellow-200 shadow-xl backdrop-blur-sm sm:text-sm">▶ {en?"Press play to watch the project in action":"Dale al play para ver el proyecto en acción"}</span><video data-project-video class="h-auto w-full object-contain" controls muted loop playsinline preload="metadata"><source src={project.video} type="video/mp4"/>{en?"Your browser cannot play this video.":"Tu navegador no puede reproducir este vídeo."}</video></>:<div class="carousel relative" data-carousel>{project.images.map((image,index)=><figure class:list={["carousel-slide aspect-video w-full",index!==0&&"hidden"]}><img class="h-full w-full object-contain" src={image} alt={(en?"Screenshot ":"Captura ")+(index+1)+(en?" of ":" de ")+project.title} loading="lazy" width="900" height="506"/></figure>)}{project.images.length>1&&<><button class="carousel-prev absolute left-3 top-1/2 grid size-10 -translate-y-1/2 place-items-center rounded-full bg-black/70 text-white hover:bg-black" type="button" aria-label={en?"Previous image":"Imagen anterior"}>←</button><button class="carousel-next absolute right-3 top-1/2 grid size-10 -translate-y-1/2 place-items-center rounded-full bg-black/70 text-white hover:bg-black" type="button" aria-label={en?"Next image":"Imagen siguiente"}>→</button><span class="carousel-count absolute bottom-3 right-3 rounded-full bg-black/70 px-3 py-1 text-xs text-white">1 / {project.images.length}</span></>}</div>}</div></div></article>)}</div>
<script is:inline>
 document.querySelectorAll("[data-project-video]").forEach(video=>video.addEventListener("play",()=>video.parentElement?.querySelector("[data-video-hint]")?.classList.add("hidden"),{once:true}));
 document.querySelectorAll("[data-carousel]").forEach(carousel=>{const slides=[...carousel.querySelectorAll(".carousel-slide")];let current=0;const count=carousel.querySelector(".carousel-count");const show=index=>{slides.forEach((slide,i)=>slide.classList.toggle("hidden",i!==index));if(count)count.textContent=(index+1)+" / "+slides.length};carousel.querySelector(".carousel-next")?.addEventListener("click",()=>{current=(current+1)%slides.length;show(current)});carousel.querySelector(".carousel-prev")?.addEventListener("click",()=>{current=(current-1+slides.length)%slides.length;show(current)})});
</script>



