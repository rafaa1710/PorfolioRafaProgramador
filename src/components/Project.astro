---
import Angular from "../icons/Angular.astro";
import Typescript from "../icons/Typescript.astro";
import Spring from "../icons/Spring.astro";
import Mariadb from "../icons/Mariadb.astro";
import Php from "../icons/Php.astro";
import Mysql from "../icons/Mysql.astro";
import AstroIcon from "../icons/Astro.astro";
import Css from "../icons/Css.astro";
const { lang = "es" } = Astro.props;
const en = lang === "en";
const base=import.meta.env.BASE_URL.endsWith("/")?import.meta.env.BASE_URL:import.meta.env.BASE_URL+"/";
const media={video:base+"result.mp4",bdi:base+"bdi-company-2.mp4",erp:[base+"sge1.jpg",base+"sge2.jpg",base+"sge3.jpg",base+"sge4.jpg",base+"sge5.jpg"]};
const projects=en?[
 {id:"bdi-company",title:"BDI Company corporate website",summary:"Development of a corporate website for a remodeling and construction company in the United States.",description:"Design and development of a professional website focused on lead generation, including a services overview, project galleries with images and videos, a contact form, responsive design for mobile and desktop, advance SEO optimization, Google Analytics integration, and production deployment through Vercel with a custom domain.",highlights:["Services overview and multimedia project galleries","Contact form focused on lead generation","Responsive design and advance SEO optimization","Google Analytics and custom domain"],tags:["Astro","CSS"],video:media.bdi,images:[]},
 {id:"trasterush",title:"Smart storage rental platform",summary:"A complete rental journey connecting a web application, payments, digital signatures and physical access.",description:"I designed a full stack solution where users check availability, complete their rental and receive a unique access code. An ESP32 validates payment status over HTTP and activates the electronic lock.",highlights:["Rental, payment and digital signature","Admin panel with full CRUD management","IoT integration for physical access","Automated Gmail notifications"],tags:["Angular","TypeScript","Spring Boot","MariaDB","ESP32"],video:media.video,images:[]},
 {id:"erp-crm",title:"Modular ERP and CRM system",summary:"Unified management of students, training, users and administrative processes for an institutional environment.",description:"I developed and integrated connected modules built on a complex relational model. The focus was maintaining data consistency and making internal management workflows clearer.",highlights:["Interconnected modules and permissions","Relational data model","Centralised administrative workflows"],tags:["Angular","TypeScript","PHP","MySQL"],images:media.erp}
]:[
 {id:"bdi-company",title:"Sitio web corporativo para BDI Company",summary:"Desarrollo y mantenimiento de sitio web corporativo para una empresa de remodelación y construcción en Estados Unidos.",description:"Diseño y desarrollo de una web profesional orientada a la captación de clientes, incluyendo presentación de servicios, galerías de proyectos con imágenes y vídeos, formulario de contacto, diseño responsive para móviles y escritorio, optimización SEO avanzada, integración con Google Analytics y dominio personalizado.",highlights:["Presentación de servicios y galerías multimedia","Formulario orientado a la captación de clientes","Diseño responsive y optimización SEO avanzada","Google Analytics y dominio personalizado"],tags:["Astro","CSS"],video:media.bdi,images:[]},
 {id:"trasterush",title:"Plataforma inteligente de alquiler de trasteros",summary:"Una experiencia de contratación completa que conecta aplicación web, pagos, firma digital y acceso físico.",description:"Diseñé una solución full stack donde el usuario consulta disponibilidad, contrata y recibe un código de acceso único. Un ESP32 valida el estado del pago mediante HTTP y acciona la cerradura electrónica.",highlights:["Contratación, pago y firma digital","Panel administrador con gestión CRUD","Integración IoT para acceso físico","Sistema de notificaciones automatizadas mediante Gmail"],tags:["Angular","TypeScript","Spring Boot","MariaDB","ESP32"],video:media.video,images:[]},
 {id:"erp-crm",title:"Sistema modular ERP y CRM",summary:"Gestión unificada de alumnos, formación, usuarios y procesos administrativos para un entorno institucional.",description:"Desarrollé e integré módulos conectados sobre un modelo relacional complejo. El foco estuvo en mantener la consistencia de la información y hacer más claros los flujos de gestión internos.",highlights:["Módulos y permisos interconectados","Modelo de datos relacional","Flujos administrativos centralizados"],tags:["Angular","TypeScript","PHP","MySQL"],images:media.erp}
];
const TAG_ICONS: Partial<Record<string, typeof Angular>>={Angular,TypeScript:Typescript,"Spring Boot":Spring,MariaDB:Mariadb,PHP:Php,MySQL:Mysql,Astro:AstroIcon,CSS:Css};
---
<div class="grid gap-10">{projects.map(project=><article id={project.id} class="glass-card overflow-hidden rounded-[2rem]"><div class="grid gap-8 p-6 sm:p-9 lg:grid-cols-[.8fr_1.4fr] lg:p-12"><div><h3 class="text-3xl font-semibold leading-tight tracking-[-.035em] text-white">{project.title}</h3><p class="mt-4 text-lg font-medium leading-7 text-white/85">{project.summary}</p><p class="mt-5 leading-7 text-white/55">{project.description}</p><ul class="mt-6 space-y-2 text-sm text-white/70">{project.highlights.map(item=><li class="flex gap-3"><span class="text-yellow-200">✓</span>{item}</li>)}</ul><ul class="mt-7 flex flex-wrap gap-2">{project.tags.map(tag=>{const Icon=TAG_ICONS[tag];return <li class="flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-xs font-medium text-white/65">{Icon&&<Icon class="size-4"/>}{tag}</li>})}</ul></div><div class="self-center overflow-hidden rounded-2xl border border-white/10 bg-black/30 shadow-2xl">{project.video?<video class="h-auto w-full object-contain" controls muted loop playsinline preload="metadata"><source src={project.video} type="video/mp4"/>{en?"Your browser cannot play this video.":"Tu navegador no puede reproducir este vídeo."}</video>:<div class="carousel relative" data-carousel>{project.images.map((image,index)=><figure class:list={["carousel-slide aspect-video w-full",index!==0&&"hidden"]}><img class="h-full w-full object-contain" src={image} alt={(en?"Screenshot ":"Captura ")+(index+1)+(en?" of ":" de ")+project.title} loading="lazy" width="900" height="506"/></figure>)}{project.images.length>1&&<><button class="carousel-prev absolute left-3 top-1/2 grid size-10 -translate-y-1/2 place-items-center rounded-full bg-black/70 text-white hover:bg-black" type="button" aria-label={en?"Previous image":"Imagen anterior"}>←</button><button class="carousel-next absolute right-3 top-1/2 grid size-10 -translate-y-1/2 place-items-center rounded-full bg-black/70 text-white hover:bg-black" type="button" aria-label={en?"Next image":"Imagen siguiente"}>→</button><span class="carousel-count absolute bottom-3 right-3 rounded-full bg-black/70 px-3 py-1 text-xs text-white">1 / {project.images.length}</span></>}</div>}</div></div></article>)}</div>
<script is:inline>
 document.querySelectorAll("[data-carousel]").forEach(carousel=>{const slides=[...carousel.querySelectorAll(".carousel-slide")];let current=0;const count=carousel.querySelector(".carousel-count");const show=index=>{slides.forEach((slide,i)=>slide.classList.toggle("hidden",i!==index));if(count)count.textContent=(index+1)+" / "+slides.length};carousel.querySelector(".carousel-next")?.addEventListener("click",()=>{current=(current+1)%slides.length;show(current)});carousel.querySelector(".carousel-prev")?.addEventListener("click",()=>{current=(current-1+slides.length)%slides.length;show(current)})});
</script>



