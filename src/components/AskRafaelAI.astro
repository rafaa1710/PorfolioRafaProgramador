  }

  .chat-footer input::placeholder {
    color: #9aa3b2;
  }

  .chat-footer button {
    flex: 0 0 46px;
    width: 46px;
    height: 46px;
    border: none;
    border-radius: 12px;
    color: #111;
    background: #f5d061;
    cursor: pointer;
    font-size: 1.1rem;
  }

  @keyframes chat-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }

    to {
      opacity: 1;
