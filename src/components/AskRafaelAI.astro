    }
  }

  @media (max-width: 520px) {
    #ai-widget {
      right: 16px;
      bottom: 16px;
    }

    .chat-window {
      right: 0;
      bottom: 78px;
      height: min(520px, calc(100vh - 110px));
    }
  }
</style>
