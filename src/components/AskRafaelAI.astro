<div id="ai-widget" aria-live="polite">
  <button
    id="toggle-chat"
    class="chat-button"
    type="button"
    aria-label="Abrir chat de Rafael AI"
    aria-expanded="false"
    aria-controls="chat-window"
  >
    <span aria-hidden="true">🤖</span>
  </button>

  <section id="chat-window" class="chat-window hidden" aria-label="Chat con Rafael AI">
    <header class="chat-header">
      <div>
        <strong>🤖 Ask Rafael AI</strong>
        <small>Preguntame sobre Rafael</small>
      </div>

      <button id="close-chat" type="button" aria-label="Cerrar chat">x</button>
    </header>

    <div class="chat-body">
      <div class="chat-message bot">
        <div>
          Hola, soy Rafael AI. Preguntame sobre mi experiencia, proyectos o tecnologias.
        </div>
      </div>
    </div>

    <form class="chat-footer" id="chat-form">
      <input
        id="question"
        type="text"
        name="question"
        placeholder="Escribe tu pregunta..."
        autocomplete="off"
      />

      <button id="send" type="submit" aria-label="Enviar mensaje">
        <span aria-hidden="true">&rarr;</span>
      </button>
    </form>
  </section>
</div>

<script>
  const widget = document.getElementById("chat-window") as HTMLElement;
  const open = document.getElementById("toggle-chat") as HTMLButtonElement;
  const close = document.getElementById("close-chat") as HTMLButtonElement;
  const form = document.getElementById("chat-form") as HTMLFormElement;
  const input = document.getElementById("question") as HTMLInputElement;
  const chatBody = document.querySelector(".chat-body") as HTMLDivElement;

  function setChatOpen(isOpen: boolean) {
    widget.classList.toggle("hidden", !isOpen);
    open.setAttribute("aria-expanded", String(isOpen));

    if (isOpen) {
      input.focus();
    }
  }

  function addMessage(text: string, type: "bot" | "user") {
    const wrapper = document.createElement("div");
    wrapper.className = `chat-message ${type}`;

    const bubble = document.createElement("div");
    bubble.textContent = text;

    wrapper.appendChild(bubble);
    chatBody.appendChild(wrapper);
    chatBody.scrollTop = chatBody.scrollHeight;

    return bubble;
  }

  async function sendMessage() {
    const message = input.value.trim();
    if (!message) return;

    addMessage(message, "user");
    input.value = "";

    const loadingMessage = addMessage("Pensando...", "bot");

    try {
      const response = await fetch("/api/chat", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ message }),
      });

      if (!response.ok) {
        throw new Error("Chat request failed");
      }

      const data = await response.json();
      loadingMessage.textContent = data.answer ?? "No he podido responder a eso.";
    } catch (error) {
      loadingMessage.textContent = "Ha ocurrido un error. Intentalo de nuevo.";
    }
  }

  open.addEventListener("click", () => {
    setChatOpen(widget.classList.contains("hidden"));
  });

  close.addEventListener("click", () => {
    setChatOpen(false);
  });

  form.addEventListener("submit", (event) => {
    event.preventDefault();
    sendMessage();
  });
</script>

<style>
  #ai-widget {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 9999;
  }

  .chat-button {
    width: 66px;
    height: 66px;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    background: #f5d061;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.34);
    cursor: pointer;
    display: grid;
    place-items: center;
    font-size: 2rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .chat-button:hover {
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.42);
  }

  .chat-window {
    position: absolute;
    right: 0;
    bottom: 82px;
    width: min(380px, calc(100vw - 32px));
    height: min(560px, calc(100vh - 120px));
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 18px;
    background: #10141c;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.45);
    animation: chat-in 0.2s ease;
  }

  .hidden {
    display: none;
  }

  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px;
    color: #fff;
    background: #080b10;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .chat-header strong {
    display: block;
    font-size: 0.98rem;
    font-weight: 720;
  }

  .chat-header small {
    display: block;
    margin-top: 3px;
    color: #a8b0bd;
    font-size: 0.78rem;
  }

  .chat-header button {
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
  }

  .chat-body {
    flex: 1;
    padding: 16px;
    overflow-y: auto;
    color: #111;
    background: #f3f5f8;
  }

  :global(.chat-message) {
    display: flex;
    width: 100%;
    margin: 10px 0;
  }

  :global(.chat-message.bot) {
    justify-content: flex-start;
  }

  :global(.chat-message.user) {
    justify-content: flex-end;
  }

  :global(.chat-message > div) {
