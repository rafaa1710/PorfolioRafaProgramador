    padding: 11px 14px;
    border-radius: 16px;
    font-size: 0.92rem;
    line-height: 1.45;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  :global(.chat-message.bot > div) {
    color: #111827;
    background: #fff;
    border-bottom-left-radius: 5px;
    box-shadow: 0 6px 18px rgba(17, 24, 39, 0.08);
  }

  :global(.chat-message.user > div) {
    color: #111;
    background: #f5d061;
    border-bottom-right-radius: 5px;
  }

  .chat-footer {
    display: flex;
    gap: 10px;
    padding: 14px;
