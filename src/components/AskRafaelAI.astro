    background: #080b10;
  }

  .chat-footer input {
    min-width: 0;
    flex: 1;
    padding: 12px 13px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 12px;
    outline: none;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
