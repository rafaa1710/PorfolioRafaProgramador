---
import Mail from "../icons/Mail.astro";
const { lang = "es" } = Astro.props;
const en = lang === "en";
const gmail="https://mail.google.com/mail/?view=cm&fs=1&to=rafaprogramador17@gmail.com&su="+(en?"Portfolio%20contact":"Contacto%20desde%20tu%20portfolio");
---
<section class="glass-card relative overflow-hidden rounded-[2rem] px-6 py-14 text-center sm:px-14 sm:py-20"><div class="absolute left-1/2 top-0 h-48 w-96 -translate-x-1/2 rounded-full bg-yellow-200/10 blur-3xl"></div><div class="relative"><p class="eyebrow">{en?"Contact":"Contacto"}</p><h2 class="mx-auto mt-4 max-w-2xl text-4xl font-bold tracking-[-.04em] text-white sm:text-5xl">{en?"Have a project or an opportunity?":"¿Tienes un proyecto o una oportunidad?"}</h2><p class="mx-auto mt-5 max-w-xl text-lg leading-8 text-white/60">{en?"I'm open to collaborating on useful products with teams that care about building things well. Tell me what you're working on.":"Estoy abierto a colaborar en productos útiles y equipos con ganas de construir bien. Cuéntame qué tienes entre manos."}</p><a href={gmail} target="_blank" rel="noopener noreferrer" class="mt-8 inline-flex items-center gap-3 rounded-full bg-yellow-200 px-7 py-3.5 font-semibold !text-black transition hover:-translate-y-0.5 hover:bg-yellow-100"><Mail class="size-5"/>{en?"Open Gmail":"Abrir Gmail"}</a><p class="mt-5 text-sm text-white/40">rafaprogramador17@gmail.com</p></div></section>
