---
import Mail from "../icons/Mail.astro";
---

<section class="mt-24 flex justify-center">
  <div
    class="w-full max-w-2xl rounded-3xl
         border border-cian-400/20
         bg-gradient-to-br from-violet-500/20 to-fuchsia-500/20
         backdrop-blur-md
         p-8 sm:p-12
         text-center
         shadow-2xl shadow-fuchsia-500/10"
  >
    <div
      class="w-16 h-16 mx-auto mb-6 rounded-2xl
             bg-yellow-200/10
             flex items-center justify-center"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-8 h-8 text-yellow-200"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M16 12H8m8 4H8m8-8H8m-2 12h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
        />
      </svg>
    </div>

    <h3 class="text-3xl font-bold mb-4">
      ¿Hablamos?
    </h3>

    <p class="text-white/70 text-lg leading-relaxed mb-8 max-w-lg mx-auto">
      Si tienes una propuesta, proyecto o colaboración,
      puedes escribirme directamente y te responderé lo antes posible.
    </p>

    <a
      href="https://mail.google.com/mail/?view=cm&fs=1&to=rafaprogramador17@gmail.com&su=Contacto%20Portfolio"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3
             rounded-2xl
             bg-yellow-200 text-black
             px-8 py-4
             font-semibold
             transition-all duration-300
             hover:scale-105
             hover:bg-yellow-100
             shadow-lg shadow-yellow-200/20"
    >
      <Mail class="w-6 h-6" />
      Contactar por Gmail
    </a>
  </div>
</section>