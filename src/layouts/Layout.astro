---
import '../styles/global.css';
import Header from '../components/Header.astro';
import '@fontsource-variable/onest';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Portfolio de Rafael Programador</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}avatar.png`} type="image/png" sizes="512x512" />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}avatar.png`} />
  </head>

  <body>
    <!-- Fondo, SOLO fondo -->
    <div class="bg" aria-hidden="true"></div>

    <!-- Contenido normal (scrolleable) -->
    <Header />
    <main class="page">
      <slot />
    </main>
    <script is:inline>
    window.history.scrollRestoration = "manual";

    window.onload = () => {
      window.scrollTo(0, 0);
    };
  </script>
  </body>
</html>

<style>
  :root { color-scheme: dark; }

  html {
    font-family: "Onest Variable", system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  body {
    background: #050505;
    margin: 0;
    
  }

  .page {
    min-height: 100vh;
    padding: 1rem 0 3rem;
  }

  .bg{
    position: fixed;
    inset: 0;
    z-index: -1;
    background: radial-gradient(125% 125% at 50% 10%, #000 40%, #63e 100%);
  }

@media (min-width: 640px) {
  .page {
    padding-top: 2rem;
  }
}

@media (min-width: 1024px) {
  .page {
    padding-top: 3rem;
  }
}
</style>
