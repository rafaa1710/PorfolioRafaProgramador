---
import "../styles/global.css";
import Header from "../components/Header.astro";
import "@fontsource-variable/onest";
const {
  lang = "es",
  title = lang === "en" ? "Rafa García — Full Stack Developer" : "Rafa García — Desarrollador Full Stack",
  description = lang === "en" ? "Portfolio of Rafa García, a full stack developer specialising in Angular, Spring Boot, PHP and databases." : "Portfolio de Rafa García, desarrollador full stack especializado en Angular, Spring Boot, PHP y bases de datos."
} = Astro.props;
---
<!doctype html><html lang={lang}><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><meta name="description" content={description}/><meta name="theme-color" content="#080b10"/><meta property="og:title" content={title}/><meta property="og:description" content={description}/><meta property="og:type" content="website"/><meta property="og:image" content={import.meta.env.BASE_URL + "fotoProg.jpg"}/><title>{title}</title><link rel="icon" href={import.meta.env.BASE_URL + "avatar.png"} type="image/png"/></head><body><a class="sr-only focus:not-sr-only fixed top-3 left-3 z-[60] rounded-lg bg-yellow-200 px-4 py-2 text-black" href="#contenido">{lang === "en" ? "Skip to content" : "Saltar al contenido"}</a><Header lang={lang}/><main id="contenido"><slot/></main></body></html>
